*
!*.html
!*.js
!*.json
!*.md
!*.php
# Build needs to recognize git
!.git/
!docs/assets
!docs/*.js
!src
!server
!plugins
!modules
!env
!ui
!/tmp/openseadragon/build
!docker/php/*.conf
!docker/php/*.sh
!.htaccess
!package.json
!package-lock.json
!tailwind.config.js

# Re-exclude compiled C/native build scratch dragged in by !modules.
# buildx rejects the dangling libtool symlinks (e.g. icc_profile lcms2
# .libs/*.la); these intermediates are regenerated by `npm run minify`.
modules/**/build
**/.libs
**/*.la