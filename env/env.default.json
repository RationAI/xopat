/**
 * THIS IS A DEFAULT CONFIGURATION FOR STANDALONE OPERATION
 * Ports are configured via environment variables (WSI_PORT, XOPAT_NODE_PORT), and
 * it is the simplest (often dev) setup. The viewer can be
 * connected to virtually _anything_, so do not be bound by this example.
*/
{
  "core": {
    // This configuration file supports JSON with comments
    "gateway": "/",
    "active_client": "localhost",
    "client": {
      "localhost": {
        "domain": "http://localhost:<% XOPAT_NODE_PORT:-9000 %>",
        "path": "/",
        "slide_protocols": {
          "wsi_service": {
            "url": "`/v3/slides/info?slide_id=${data}`",
            "baseURL": "http://localhost:<% WSI_PORT:-8080 %>"
          }
        },
        "default_background_protocol": "wsi_service",
        "default_visualization_protocol": "wsi_service",
        "headers": {},
        "js_cookie_expire": 365,
        "js_cookie_path": "/",
        "js_cookie_same_site": "",
        "js_cookie_secure": "",
        "secureMode": false,
        "pluginSelectionMode": "<% XOPAT_PLUGIN_SELECTION_MODE:-all %>"
      }
    },
    "setup": {
      "locale": "en",
      "theme": "auto",
      "disablePluginsUi": "<% XOPAT_DISABLE_PLUGINS_UI:-false %>",
      "scrollRequiresCtrl": "<% XOPAT_SCROLL_REQUIRES_CTRL:-false %>",
      "bypassCloseConfirmation": "<% XOPAT_BYPASS_CLOSE_CONFIRMATION:-false %>"
      // Custom branding — operator-trusted (ENV only, never overridable by a
      // session bundle / URL params). Any key omitted falls back to the stock
      // xOpat asset, so leaving this block out changes nothing. Icon/logo values
      // are page-root-relative URLs (or absolute). `logo` renders a company
      // image at the left of the top app bar.
      // "branding": {
      //   "title": "My Pathology Viewer",
      //   "appleTouchIcon": "src/assets/apple-touch-icon.png",
      //   "icon32": "src/assets/favicon-32x32.png",
      //   "icon16": "src/assets/favicon-16x16.png",
      //   "maskIcon": "src/assets/safari-pinned-tab.svg",
      //   "maskIconColor": "#5bbad5",
      //   "logo": "src/assets/my-company-logo.svg"
      // }
    },
    // Roles & capabilities — UI gating only (real authorization is the
    // embedding backend's job). See src/USER_ROLES.md. Leave the
    // `definitions` block empty (or remove the `roles` block entirely) to
    // disable gating: every declared capability falls back to its plugin
    // default.
    //
    // Example:
    //   "roles": {
    //     "default": ["viewer"],
    //     "definitions": {
    //       "viewer": { "label": "Read-only viewer",
    //                   "deny":  ["annotations.crud:annotation.*"] },
    //       "editor": { "extends": ["viewer"],
    //                   "grant": ["annotations.crud:annotation.create",
    //                             "annotations.crud:annotation.update",
    //                             "annotations.crud:annotation.delete"] },
    //       "admin":  { "extends": ["editor"], "grant": ["*"] }
    //     }
    //   }
    "roles": {
      "default": [],
      "definitions": {}
    }
  },
  "plugins": {
    "slide-info": {
      "permaLoad": true
    },
    "rationai-wsi-file-browser": {
      "permaLoad": true,
      "wsiService": "http://localhost:<% WSI_PORT:-8080 %>"
    },
    "extra-tutorials": {
      "enabled": "true"
    }
  },
  "modules": {
    "rationai-wsi-tile-source": {
      "permaLoad": true
    }
  }
}
