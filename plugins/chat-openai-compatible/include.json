{
  "id": "chat-openai-compatible",
  "name": "%meta.name%",
  "author": "RationAI",
  "version": "1.0.0",
  "description": "%meta.description%",
  "categories": ["AI"],
  "keywords": ["chat", "llm", "openai", "gpt"],
  "icon": "ph-chat-circle-dots",
  "modules": ["oidc-client-ts", "vercel-ai-chat-sdk"],
  // none or jwt — secures the viewer (proxy) endpoint, NOT the upstream model
  "authMode": "jwt",
  // if null, inherits the core auth context (same as viewer login)
  "authContext": null,
  "oidc": {
    "authority": "https://your-auth-server.com",
    "client_id": "openai-plugin-client",
    "scope": "openid profile chat_api"
  }
}
