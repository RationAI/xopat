{
  "description": "Cerit-IO Hosted Model provider integration.",
  "modules": ["vercel-ai-chat-sdk"],
  "providerTypeId": "cerit-llm-ai",
  // alias key to use in server proxy
  "baseUrl": "https://llm.ai.e-infra.cz/",
  "modelsDiscoveryPath": "/v1/models",
  "defaultModelId": "",
  // none or jwt, this auth secures viewer (proxy) endpoint, NOT the model
  "authMode": "jwt",
  // if set to null, it inherits the core auth context (same as viewer login)
  "authContext": "cerit-io",
  // TODO: plugins should be able to configure auth by a generic way (e.g. just pass it to some resolver)
  "oidc": {
    "authority": "https://your-auth-server.com",
    "client_id": "openai-plugin-client",
    "scope": "openid profile chat_api"
  }
}