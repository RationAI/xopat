# allow only built-in items in modules/plugins
# Only top-level entries in modules/ and plugins/ are ignored;
# once a directory below is un-ignored, all of its contents are tracked normally.
/modules/*
!/modules/annotations
!/modules/chat
!/modules/empaia-wsi-tile-source
!/modules/empation-api
!/modules/fabricjs
!/modules/geotiff
!/modules/human-readable-ids
!/modules/icc_profile
!/modules/jwt-decode
!/modules/menu-pages
!/modules/mlflow
!/modules/oidc-client-ts
!/modules/pollyjs
!/modules/rationai-wsi-tile-source
!/modules/sanitize-html
!/modules/snapshots
!/modules/vega
!/modules/vega-secure
!/modules/webgl
!/modules/sam-segmentation-experimental
!/modules/web-worker-manager

/plugins/*
!/plugins/annotations
!/plugins/analyze-dev
!/plugins/chat-anthropic
!/plugins/chat-openai-compatible
!/plugins/custom-pages
!/plugins/empaia
!/plugins/extra-tutorials
!/plugins/rationai-wsi-file-browser
!/plugins/hotkeys
!/plugins/navigation-tracker
!/plugins/profiler
!/plugins/questionaire
!/plugins/recorder
!/plugins/user-session
!/plugins/youtrack-feedback-form
!/plugins/sam-segment-tool-experimental
!/plugins/dicom
!/plugins/slide-info

#rubbish
*.txt
*.old
*.temp
.idea/
Thumbs.db

#builds and binaries
*.min.js
*.min.js.map
/openseadragon/
/openseadragon-new/
/node_modules/
/build/
/coverage/
/env/
!env/README.md
!env/env.default.json
dist

#docs
/docs/build/
!docs/doctemplates/openseadragon

#docs site (Docusaurus) — generated content and build outputs
/docs/site/node_modules/
/docs/site/build/
/docs/site/.docusaurus/
/docs/site/static/api/
/docs/site/docs/generated/

#test suite data
/test/downloads/
/test/screenshots/
/test/videos/
/wsi_data

#sensitive data
cypress.env.*

#image comparison test temp data
*.diff.png
*.actual.png

#all hidden files unless explicitly added
.*

# hidden docs file
!.readthedocs.yaml

# CI workflows must stay tracked despite the catch-all dotfile rule above
# (un-ignore the directory, then re-ignore everything but workflows/)
!/.github/
/.github/*
!/.github/workflows/
# GitHub Pages marker served with the docs site
!/docs/site/static/.nojekyll

#ui
ui/index.js
ui/index.js.map