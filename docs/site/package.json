{
  "name": "xopat-docs-site",
  "version": "1.0.0",
  "private": true,
  "description": "xOpat documentation site (Docusaurus). Self-contained: not part of the root npm workspaces.",
  "scripts": {
    "sync": "node scripts/sync-docs.mjs && node scripts/generate-catalogue.mjs",
    "prestart": "npm run sync",
    "start": "docusaurus start",
    "prebuild": "npm run sync",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear"
  },
  "dependencies": {
    "@docusaurus/core": "^3.6.0",
    "@docusaurus/preset-classic": "^3.6.0",
    "@docusaurus/theme-mermaid": "^3.6.0",
    "@easyops-cn/docusaurus-search-local": "^0.46.1",
    "comment-json": "^4.2.3",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": ["last 3 chrome version", "last 3 firefox version", "last 5 safari version"]
  },
  "engines": {
    "node": ">=18.0"
  }
}
