{
    "id": "annotations",
    "name": "Annotations Module",
    "description": "A module that brings annotations functionality.",
    "version": "0.1.0",
    "includes" : [
        "annotations.js",
        "ext/Sortable.min.js",
        "ext/greiner-hormann.min.js",
        "ext/magic-wand.js",
        "ext/polygon-intersect.js",
        "ext/rbush.min.js",
        "scripting/read.scripts.js",
        "scripting/write.scripts.js",
        "spatial-index.js",
        "workspace.js",
        "annotations-canvas.js",
        "convert/convertor.js",
        "convert/native.js",
        "convert/asapXml.js",
        "convert/geoJSON.js",
        "convert/qupath.js",
        "magic-wand.js",
        "viewport-segmentation.js",
        "fixed-area-mode.js",
        "presets.js",
        "objects.js",
        "objectGenericFactories.js",
        "objectAdvancedFactories.js",
        "freeFormTool.js"
    ],
    "requires": ["fabricjs"],
    // Generic IO pipeline declarations. Bundle-* covers the legacy
    // whole-canvas export/import (see src/IO_PIPELINE.md). Per-element
    // CRUD via "crud:annotation" / "crud:preset" stays inert until an
    // admin binds the capability to a sink.
    "io": {
        "capabilities": [
            { "id": "bundle-export", "kind": "bundle", "label": "Annotations bundle export" },
            { "id": "bundle-import", "kind": "bundle", "label": "Annotations bundle import" },
            { "id": "crud:annotation", "kind": "crud", "label": "Annotation" },
            { "id": "crud:preset",     "kind": "crud", "label": "Preset" }
        ]
    },
    // Whether to include private annotations in module export
    "exportPrivate" : false,
    // If default preset should be provided
    "provideDefaultPresets": true,
    //Arguments to format convertors
    "convertors": {
        "format": "native",
        //Account for cropping done by BioFormats and OpenSlide
        //can be overridden by convertors.imageCoordinatesOffset in plugin arguments
        "imageCoordinatesOffset": [0,0],
        //when set to false, the export output is in the native object, useful for subsequent processing,
        //e.g. consuming the object/element and uploading it to some server
        "serialize": true,
        //list of IDs to export, mostly set programmatically when export is really called
        "filter": null
    }
}
