{
  "id": "chat-based-tester",
  "name": "Chat Based Tester",
  "description": "Developer chat harness for viewer testing using vercel-ai-chat-sdk",
  "requires": ["vercel-ai-chat-sdk"],
  "permaLoad": true,
  "stability": "experimental",
  "defaultTestMode": "host",
  "defaultAttachScreenshot": false,
  "defaultIncludeServerLogs": true,
  "defaultIncludeConsoleLogs": true,
  "defaultIncludeWorkspaceDocs": true,
  "consoleLogBufferSize": 5000,
  "bootstrapMaxFileChars": 3000,
  "maxAutomationSteps": 8
}
