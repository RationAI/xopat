{
  "name": "AI Chat",
  "icon": "ph-chats-circle",
  "description": "Integration hub for AI chat models",
  "requires": [
    "oidc-client-ts",
    "@xopat-npm-module/marked",
    "sanitize-html",
    "speech-to-text"
  ],
  "defaultPersonalityId": "pathology-assistant",
  // Operator's preferred provider to auto-select when the user has no remembered choice (null = first
  // available, or a server provider tagged metadata.role="default-provider").
  "defaultProviderId": null,
  // Remember the user's scripting-access consent locally so returning users are not re-greeted.
  "rememberConsent": true,
  "consentRememberDays": 30,
  // Anonymize slide identity before it reaches the upstream LLM (§7 defense-in-depth). The
  // model only ever sees stable opaque handles ("viewer-1", ...) as viewer contextId/background;
  // tool-call round-trips (setActiveViewer/getGlobalInfo/viewer.*/annotations*) stay reliable
  // because the handle is an opaque join key translated back host-side. Deployment (ENV) only —
  // read via static meta, so an imported session bundle cannot downgrade it. One of:
  //   "off"     - send the real background id/name (only if the operator asserts they carry no PII)
  //   "handles" - opaque ids, but keep the real operator display name (imageName)
  //   "full"    - opaque ids AND names; the friendly name is restored only when rendering to the
  //               local user. Default.
  "anonymizeViewerContext": "full",
  "personalities": [
    {
      "id": "pathology-assistant",
      "label": "Pathology Assistant",
      "systemPrompt": "You are a pathology slide-review assistant. Be concise. Prefer structured answers. When unsure, ask targeted questions."
    }
  ],
  "maxScriptSteps": 12,
  "maxScriptStepExtensions": 2,
  "scriptStepExtensionSize": 4,
  "minSuccessfulProgressStepsBeforeExtension": 4,
  "defaultGrantedNamespaces": [
    // Operator-trusted scripting namespaces granted to the chat agent without a
    // per-user consent dialog, e.g. ["pathology"]. Deployment (ENV) config only —
    // read via static meta, so an imported session bundle cannot inject grants.
  ],
  "voice": {
    // See ChatVoiceControllerOptions
  }
}
